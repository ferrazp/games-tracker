{
  "name": "games-backend",
  "version": "1.3.0",
  "description": "Games Tracker Backend - API REST para seguimiento de videojuegos con soporte dual SQLite/PostgreSQL",
  "main": "server-unified.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server-unified.js",
    "dev": "node server-unified.js",
    "dev:sqlite": "set DB_TYPE=sqlite && node server-unified.js",
    "dev:postgres": "set DB_TYPE=postgresql && node server-unified.js",
    "start:sqlite": "set DB_TYPE=sqlite && node server-unified.js",
    "start:postgres": "set DB_TYPE=postgresql && node server-unified.js",
    "seed:catalog": "node scripts/seed-catalog.js",
    "migrate": "node db/migrate.js",
    "test": "node --test \"tests/**/*.test.js\"",
    "test:coverage": "node --experimental-test-coverage --test \"tests/**/*.test.js\"",
    "test:verbose": "node --test --test-reporter spec \"tests/**/*.test.js\"",
    "test:coverage:verbose": "node --experimental-test-coverage --test --test-reporter spec \"tests/**/*.test.js\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "pino": "^10.3.1"
  },
  "type": "module",
  "devDependencies": {
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2"
  }
}
