# Twitch API Credentials (OPCIONAL - búsqueda local funciona igual)
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# Server Configuration
PORT=4000
NODE_ENV=development

# Database Type: sqlite (default) or postgresql
DB_TYPE=sqlite

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# PostgreSQL Configuration (only used if DB_TYPE=postgresql)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=games_tracker
DB_USER=postgres
DB_PASSWORD=postgres

# API Key (OPCIONAL - para endpoints protegidos /stats, /export, /import)
# Si está vacío, los endpoints son públicos (solo red local)
# API_KEY=tu-clave-secreta

# Log Level (debug | info | warn | error)
LOG_LEVEL=debug
